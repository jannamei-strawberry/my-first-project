# Ask the user to input 5 grades in 5 subjects 

while True:
    try:
        Math_grade = int(input("Please enter the grade for Mathematics: "))
        if Math_grade <= 0:
            print("Invalid input. Please enter a positive number.")
        else:
            break
    except ValueError:
        print("Invalid input. Please enter a positive number.")

